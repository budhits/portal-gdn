# Salin file ini menjadi `.env` lalu sesuaikan nilainya.
# JANGAN commit file .env yang berisi rahasia asli.

# Koneksi PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portal_gdn

# Setel "true" bila database mewajibkan SSL (umumnya di hosting managed:
# Render/Railway/Neon/Supabase). Untuk PostgreSQL lokal biarkan "false".
DATABASE_SSL=false

# "production" saat deploy (membuat server menyajikan frontend hasil build).
NODE_ENV=development

# Port server backend (di hosting biasanya diisi otomatis lewat $PORT)
PORT=4000

# Rahasia untuk menandatangani token login (JWT). Ganti dengan string acak panjang.
JWT_SECRET=ubah-ini-dengan-string-acak-yang-panjang-dan-rahasia
JWT_EXPIRES_IN=7d

# Asal frontend yang diizinkan (CORS). Pisahkan dengan koma jika lebih dari satu.
CORS_ORIGIN=http://localhost:5173

# Login dengan Google (opsional). Isi dengan OAuth 2.0 Client ID dari Google
# Cloud Console (Credentials -> Create OAuth client ID -> Web application).
# Kosongkan untuk menonaktifkan tombol "Masuk dengan Google".
GOOGLE_CLIENT_ID=
