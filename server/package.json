{
  "name": "portal-gdn-server",
  "version": "1.0.0",
  "description": "Backend API untuk Portal GDN — Sistem Planning & Monitoring Bisnis",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "db:schema": "node db/run-schema.js",
    "db:seed": "node db/seed.js",
    "db:reset": "node db/run-schema.js && node db/seed.js",
    "db:clear-trial": "node db/clear-trial.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  }
}
